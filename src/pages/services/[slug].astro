---
import Base from '../../layouts/Base.astro';
import { loadAggregated, loadServiceSpec } from '../../lib/services';

export function getStaticPaths() {
  const idx = loadAggregated();
  return idx.services.map((svc) => ({
    params: { slug: svc.slug },
    props: { svc },
  }));
}

const { svc } = Astro.props as { svc: ReturnType<typeof loadAggregated>['services'][number] };
const spec = loadServiceSpec(svc.slug) as any;

interface FlatEndpoint {
  method: string;
  path: string;
  summary: string;
}
const endpoints: FlatEndpoint[] = [];
const methods = ['get', 'post', 'put', 'patch', 'delete', 'options', 'head'];
if (spec?.paths && typeof spec.paths === 'object') {
  for (const [pathKey, pathItem] of Object.entries(spec.paths as Record<string, any>)) {
    if (!pathItem || typeof pathItem !== 'object') continue;
    for (const m of methods) {
      const op = (pathItem as any)[m];
      if (!op) continue;
      endpoints.push({
        method: m,
        path: pathKey,
        summary: op.summary || op.operationId || '',
      });
    }
  }
}
endpoints.sort((a, b) => a.path.localeCompare(b.path) || a.method.localeCompare(b.method));

const fetchedAtPretty = svc.fetchedAt && svc.fetchedAt !== new Date(0).toISOString()
  ? new Date(svc.fetchedAt).toUTCString()
  : 'never';

const specUrl = `/api/${svc.slug}.openapi.json`;
---
<Base title={`${svc.name} API`} description={svc.description} active="services">
  <section class="detail-head">
    <div class="crumbs">
      <a href="/">Services</a> &nbsp;/&nbsp; <span>{svc.slug}</span>
    </div>
    <h1>{svc.name}</h1>
    <p style="color: var(--text-dim); max-width: 720px; margin-top: 4px;">{svc.description}</p>
    <div class="meta-row">
      <span class={`badge ${svc.status}`}>
        <span class="dot" aria-hidden="true"></span>
        {svc.status}
      </span>
      <span>HTTP {svc.httpStatus || '—'}</span>
      <span>{svc.elapsedMs} ms</span>
      <span>last sync: {fetchedAtPretty}</span>
      <span>domain: {svc.domain}</span>
      <span><a href={svc.url} target="_blank" rel="noopener">upstream openapi.json</a></span>
      {spec && <span><a href={specUrl}>cached spec</a></span>}
    </div>
  </section>

  {!spec && (
    <section style="margin-top: 28px;">
      <div class={`notice ${svc.status === 'unavailable' ? 'bad' : ''}`}>
        No OpenAPI spec on disk for <span class="mono">{svc.slug}</span>.
        Last upstream check: HTTP <span class="mono">{svc.httpStatus}</span>
        {svc.error && <> · <span class="mono">{svc.error}</span></>}.
        The aggregator will retry on the next nightly run.
      </div>
    </section>
  )}

  {spec && (
    <>
      <section style="margin-top: 28px;">
        <div class="section-head">
          <h2>Overview</h2>
          <div class="meta">openapi {spec.openapi || '—'}</div>
        </div>
        <div class="svc-card" style="cursor: default;">
          <div class="name">{spec.info?.title || svc.name}</div>
          <div class="desc">{spec.info?.description || svc.description}</div>
          <div class="foot">
            <span class="domain">version {spec.info?.version || '—'}</span>
            <span class="numeral">{endpoints.length} endpoints</span>
          </div>
        </div>
      </section>

      <section style="margin-top: 28px;">
        <div class="section-head">
          <h2>Endpoints</h2>
          <div class="meta">{endpoints.length} total</div>
        </div>
        {endpoints.length === 0 && (
          <div class="notice">This service exposes no documented paths.</div>
        )}
        {endpoints.map((ep) => (
          <div class="endpoint">
            <div class="row">
              <span class={`method ${ep.method}`}>{ep.method}</span>
              <span class="path">{ep.path}</span>
              {ep.summary && <span class="summary">{ep.summary}</span>}
            </div>
          </div>
        ))}
      </section>
    </>
  )}
</Base>
